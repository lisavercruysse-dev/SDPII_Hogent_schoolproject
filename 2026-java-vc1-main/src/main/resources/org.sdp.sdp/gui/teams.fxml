<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<fx:root style="-fx-background-color: white;" type="javafx.scene.layout.VBox" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1">
    <children>
        <StackPane stylesheets="@../../styles/styles.css" VBox.vgrow="ALWAYS">
            <children>
            <HBox>
               <children>
                      <VBox spacing="16.0" HBox.hgrow="ALWAYS">
                          <children>
                        <Label styleClass="page-titel" text="Teams">
                           <VBox.margin>
                              <Insets />
                           </VBox.margin>
                           <padding>
                              <Insets bottom="10.0" left="20.0" right="20.0" top="20.0" />
                           </padding></Label>
                              <TableView fx:id="teamsTbl" maxHeight="400.0" prefHeight="400.0" style="-fx-border-color: #E5E5E5; -fx-border-width: 1 0 0 0;" styleClass="table" VBox.vgrow="ALWAYS">
                                  <columns>
                                      <TableColumn fx:id="naamCol" minWidth="100.0" prefWidth="130.0" text="naam" />
                                      <TableColumn fx:id="verantwoordelijkeCol" prefWidth="150" text="verantwoordelijke" />
                                      <TableColumn fx:id="siteCol" prefWidth="110.0" text="site" />
                                      <TableColumn fx:id="aantalLedenCol" prefWidth="120.0" text="aantal leden" />
                              <TableColumn fx:id="statusCol" prefWidth="85.0" text="Status" />
                              <TableColumn fx:id="teamsBtnCol" prefWidth="60.0">
                                 <graphic>
                                    <Button mnemonicParsing="false" onAction="#resetFilters" styleClass="resetBtn" text="↻ Reset&#10;" />
                                 </graphic></TableColumn>
                                  </columns>
                                  <VBox.margin>
                                      <Insets />
                                  </VBox.margin>
                           <columnResizePolicy>
                              <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                           </columnResizePolicy>
                              </TableView>
                        <VBox spacing="15.0" style="-fx-border-color: #E5E5E5; -fx-border-width: 1 0 0 0;">
                           <children>
                              <Label styleClass="h2" text="Team Details" />
                              <VBox fx:id="detailContainer">
                                 <children>
                                    <HBox spacing="150.0">
                                       <children>
                                          <VBox prefHeight="400.0" prefWidth="202.0" spacing="15.0">
                                             <children>
                                                <Label styleClass="h3" text="Algemeen" />
                                                <VBox spacing="5.0">
                                                   <children>
                                                      <Label styleClass="h4" text="Naam" />
                                                      <Label fx:id="naamDetail" text="Label" />
                                                   </children>
                                                </VBox>
                                                <VBox spacing="5.0">
                                                   <children>
                                                      <Label styleClass="h4" text="Verantwoordelijke" />
                                                      <Label fx:id="verantwoordelijkeDetail" text="Label" />
                                                   </children>
                                                </VBox>
                                                <VBox spacing="5.0">
                                                   <children>
                                                      <Label styleClass="h4" text="Aantal leden" />
                                                      <Label fx:id="aantalLedenDetail" text="Label" />
                                                   </children>
                                                </VBox>
                                             </children>
                                          </VBox>
                                          <VBox maxHeight="400" maxWidth="800" spacing="15.0" HBox.hgrow="ALWAYS">
                                             <children>
                                                <Label styleClass="h3" text="Werknemers" />
                                                 <VBox alignment="TOP_CENTER" style="-fx-border-color: #E5E5E5; -fx-border-radius: 15; -fx-background-radius: 15; -fx-padding: 0 0 10 0;">
                                                     <children>
                                                         <TableView fx:id="werknemersTable">
                                                             <columns>
                                                                 <TableColumn fx:id="achternaamCol" prefWidth="150.0" text="Achternaam" />
                                                                 <TableColumn fx:id="voornaamCol" prefWidth="150.0" text="Voornaam" />
                                                                 <TableColumn fx:id="emailCol" prefWidth="300.0" text="Email" />
                                                                 <TableColumn fx:id="btnCol" prefWidth="150.0" />
                                                             </columns>
                                                             <styleClass>
                                                                 <String fx:value="table" />
                                                                 <String fx:value="table-secondary" />
                                                             </styleClass>
                                                         </TableView>
                                                         <Button mnemonicParsing="false" onAction="#onWerknemerToevoegenAction" styleClass="confirmButton" text="Toevoegen" />
                                                     </children>
                                                 </VBox>
                                             </children>
                                          </VBox>
                                       </children>
                                    </HBox>
                                 </children>
                              </VBox>
                              <VBox fx:id="placeholderContainer" alignment="CENTER">
                                 <children>
                                    <ImageView fitHeight="250.0" pickOnBounds="true" preserveRatio="true">
                                       <image>
                                          <Image url="@../../images/empty%20box.png" />
                                       </image>
                                    </ImageView>
                                    <Label styleClass="h2" text="Geen Details" textAlignment="CENTER" />
                                    <Label prefHeight="41.0" prefWidth="230.0" text="Selecteer een team in de lijst om details van een team te zien." textAlignment="CENTER" wrapText="true" />
                                 </children></VBox>
                           </children>
                           <VBox.margin>
                              <Insets />
                           </VBox.margin>
                           <padding>
                              <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
                           </padding>
                        </VBox>
                          </children>
                      </VBox>
                  <VBox fx:id="teamsForm" alignment="TOP_CENTER" maxWidth="400.0" prefWidth="400.0" spacing="20.0" styleClass="rightPanelForm">
                     <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                     </padding>
                     <children>
                        <VBox>
                           <children>
                              <Label fx:id="title" styleClass="h2" text="Team Toevoegen" />
                              <Label style="-fx-font-size: 11; -fx-text-fill: gray;" text="Velden met een * zijn verplicht." />
                           </children>
                        </VBox>
                        <VBox spacing="5.0">
                           <children>
                              <Label text="Naam *" />
                              <TextField fx:id="naamInput" promptText="naam" styleClass="inputField" />
                              <Label fx:id="naamError" styleClass="error" />
                           </children></VBox>
                        <VBox spacing="5.0">
                           <children>
                              <Label text="Site *" />
                              <ComboBox fx:id="siteInput" prefHeight="27.0" prefWidth="397.0" styleClass="inputField" />
                              <Label fx:id="siteError" styleClass="error" />
                           </children>
                        </VBox>
                        <VBox>
                           <children>
                              <Label text="Verantwoordelijke *" />
                              <ComboBox fx:id="verantwoordelijkeInput" prefHeight="27.0" prefWidth="664.0" styleClass="inputField" />
                              <Label fx:id="verantwoordelijkeError" styleClass="error" />
                           </children>
                        </VBox>
                        <HBox alignment="TOP_CENTER" prefWidth="400.0" spacing="15.0">
                           <children>
                              <Button fx:id="annuleerEditBtn" mnemonicParsing="false" onAction="#onCancelEdit" styleClass="cancelButton" text="Annuleren" />
                              <Button fx:id="toevoegenBtn" mnemonicParsing="false" onAction="#toevoegenAction" style="-fx-font-weight: bold;" styleClass="confirmButton" text="Toevoegen" />
                           </children>
                        </HBox>
                     </children></VBox>
               </children>
            </HBox>
            </children>
        </StackPane>
    </children>
</fx:root>
