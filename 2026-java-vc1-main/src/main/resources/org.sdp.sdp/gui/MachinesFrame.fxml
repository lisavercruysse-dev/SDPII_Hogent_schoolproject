<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<fx:root style="-fx-background-color: white;" stylesheets="@../../styles/styles.css" type="javafx.scene.layout.HBox" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1">
    <children>
        <VBox spacing="10.0" HBox.hgrow="ALWAYS">
            <children>
                <Label styleClass="page-titel" text="Beheer machines">
               <padding>
                  <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
               </padding></Label>
                <TableView fx:id="tblMachines" maxHeight="400.0" prefHeight="400.0" styleClass="table" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="codeCol" text="Machinecode" />
                        <TableColumn fx:id="siteCol" text="Site" />
                        <TableColumn fx:id="datumOnderhoudCol" prefWidth="150.0" text="Datum laatste onderhoud" />
                        <TableColumn fx:id="productieStatusCol" text="Productiestatus" />
                        <TableColumn fx:id="statusCol" text="Status" />
                        <TableColumn fx:id="actieCol" maxWidth="90.0" minWidth="90.0" prefWidth="90.0" text="" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>

                <VBox style="-fx-border-color: #E5E5E5; -fx-border-width: 1 0 0 0;">
                    <padding>
                        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
                    </padding>
                    <children>
                        <Label styleClass="h2" text="Machine Details">
                            <VBox.margin>
                                <Insets bottom="15.0" />
                            </VBox.margin>
                        </Label>

                        <VBox fx:id="boxGeenDetails" alignment="CENTER" prefHeight="150.0" spacing="10.0">
                            <ImageView fitHeight="250.0" pickOnBounds="true" preserveRatio="true">
                                <image>
                                    <Image url="@../../images/empty%20box.png" />
                                </image>
                            </ImageView>
                            <Label styleClass="h2" text="Geen Details" />
                            <Label style="-fx-text-fill: #808080;" text="Selecteer een machine in de lijst om details van een machine te zien." />
                        </VBox>

                        <GridPane fx:id="boxWelDetails" hgap="40.0" managed="false" vgap="10.0" visible="false">
                            <columnConstraints>
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" />
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" />
                            </columnConstraints>
                            <children>
                                <Label style="-fx-font-weight: bold;" text="Algemeen" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                                <Label style="-fx-font-weight: bold; -fx-text-fill: gray; -fx-font-size: 11px;" text="Code" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                                <Label fx:id="lblDetailCode" text="..." GridPane.columnIndex="0" GridPane.rowIndex="2" />
                                <Label style="-fx-font-weight: bold; -fx-text-fill: gray; -fx-font-size: 11px;" text="Status" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                                <Label fx:id="lblDetailStatus" text="..." GridPane.columnIndex="0" GridPane.rowIndex="4" />
                                <Label style="-fx-font-weight: bold; -fx-text-fill: gray; -fx-font-size: 11px;" text="Product" GridPane.columnIndex="0" GridPane.rowIndex="5" />
                                <Label fx:id="lblDetailProduct" text="..." GridPane.columnIndex="0" GridPane.rowIndex="6" />

                                <Label style="-fx-font-weight: bold;" text="Locatie &amp; Onderhoud" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                                <Label style="-fx-font-weight: bold; -fx-text-fill: gray; -fx-font-size: 11px;" text="Locatie in Site" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                                <Label fx:id="lblDetailLocatie" text="..." GridPane.columnIndex="1" GridPane.rowIndex="2" />
                                <Label style="-fx-font-weight: bold; -fx-text-fill: gray; -fx-font-size: 11px;" text="Laatste onderhoud" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                                <Label fx:id="lblDetailOnderhoud" text="..." GridPane.columnIndex="1" GridPane.rowIndex="4" />
                            </children>
                        </GridPane>
                    </children>
                </VBox>
            </children>
        </VBox>

        <StackPane prefWidth="400.0">
            <children>
                <VBox fx:id="vboxToevoegen" alignment="TOP_CENTER" prefHeight="200.0" prefWidth="400.0" spacing="20.0" styleClass="rightPanelForm">
                    <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                    </padding>
                    <children>
                        <VBox spacing="2.0">
                            <Label styleClass="h2" text="Machine Toevoegen" />
                            <Label style="-fx-font-size: 11px; -fx-text-fill: gray;" text="Velden met een * zijn verplicht." />
                        </VBox>
                        <VBox spacing="2.0">
                            <Label text="Code *" />
                            <TextField fx:id="txtAddCode" promptText="bijv. MC-PLT-001" styleClass="inputField" />
                            <Label fx:id="lblAddCodeError" textFill="RED" style="-fx-font-size: 11px;" />
                        </VBox>
                        <VBox spacing="2.0">
                            <Label text="Site *" />
                            <ComboBox fx:id="cmbAddSite" maxWidth="Infinity" promptText="Selecteer Site" styleClass="inputField" />
                            <Label fx:id="lblAddSiteError" textFill="RED" style="-fx-font-size: 11px;" />
                        </VBox>
                        <VBox spacing="2.0">
                            <Label text="Locatie *" />
                            <TextField fx:id="txtAddLocatie" promptText="bijv. 1.003" styleClass="inputField" />
                            <Label fx:id="lblAddLocatieError" textFill="RED" style="-fx-font-size: 11px;" />
                        </VBox>
                        <VBox spacing="2.0">
                            <Label text="Product *" />
                            <TextField fx:id="txtAddProduct" promptText="bijv. Spijkers" styleClass="inputField" />
                            <Label fx:id="lblAddProductError" textFill="RED" style="-fx-font-size: 11px;" />
                        </VBox>
                        <VBox spacing="2.0">
                            <Label text="Status *" />
                            <ComboBox fx:id="cmbAddStatus" maxWidth="Infinity" styleClass="inputField" />
                            <Label fx:id="lblAddStatusError" textFill="RED" style="-fx-font-size: 11px;" />
                        </VBox>
                        <VBox spacing="2.0">
                            <Label text="Productiestatus *" />
                            <ComboBox fx:id="cmbAddProductieStatus" maxWidth="Infinity" styleClass="inputField" />
                            <Label fx:id="lblAddProdStatusError" textFill="RED" style="-fx-font-size: 11px;" />
                        </VBox>
                        <Button onAction="#btnToevoegenAction" style="-fx-font-weight: bold;" styleClass="confirmButton" text="Toevoegen" />
                    </children>
                </VBox>

                <VBox fx:id="vboxWijzigen" managed="false" spacing="15.0" style="-fx-background-color: white; -fx-border-color: #e0e0e0; -fx-border-radius: 5; -fx-background-radius: 5;" styleClass="rightPanelForm" visible="false">
                    <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                    </padding>
                    <children>
                        <Label style="-fx-font-size: 16px; -fx-font-weight: bold;" text="Machine Wijzigen" />
                        <VBox spacing="2.0">
                            <Label text="Code *" />
                            <TextField fx:id="txtEditCode" styleClass="inputField" />
                            <Label fx:id="lblEditCodeError" textFill="RED" style="-fx-font-size: 11px;" />
                        </VBox>
                        <VBox spacing="2.0">
                            <Label text="Site *" />
                            <ComboBox fx:id="cmbEditSite" maxWidth="Infinity" styleClass="inputField" />
                            <Label fx:id="lblEditSiteError" textFill="RED" style="-fx-font-size: 11px;" />
                        </VBox>
                        <VBox spacing="2.0">
                            <Label text="Locatie *" />
                            <TextField fx:id="txtEditLocatie" styleClass="inputField" />
                            <Label fx:id="lblEditLocatieError" textFill="RED" style="-fx-font-size: 11px;" />
                        </VBox>
                        <VBox spacing="2.0">
                            <Label text="Product *" />
                            <TextField fx:id="txtEditProduct" styleClass="inputField" />
                            <Label fx:id="lblEditProductError" textFill="RED" style="-fx-font-size: 11px;" />
                        </VBox>
                        <VBox spacing="2.0">
                            <Label text="Status *" />
                            <ComboBox fx:id="cmbEditStatus" maxWidth="Infinity" styleClass="inputField" />
                            <Label fx:id="lblEditStatusError" textFill="RED" style="-fx-font-size: 11px;" />
                        </VBox>
                        <VBox spacing="2.0">
                            <Label text="Productiestatus *" />
                            <ComboBox fx:id="cmbEditProductieStatus" maxWidth="Infinity" styleClass="inputField" />
                            <Label fx:id="lblEditProdStatusError" textFill="RED" style="-fx-font-size: 11px;" />
                        </VBox>
                        <Region VBox.vgrow="ALWAYS" />
                        <HBox spacing="10.0">
                            <children>
                                <Button maxWidth="Infinity" onAction="#btnAnnulerenWijzig" style="-fx-padding: 8 0; -fx-background-radius: 4; -fx-cursor: hand;" text="Annuleren" HBox.hgrow="ALWAYS" />
                                <Button maxWidth="Infinity" onAction="#btnOpslaanWijzigAction" style="-fx-background-color: #4a6ee0; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 0; -fx-background-radius: 4; -fx-cursor: hand;" text="Opslaan" HBox.hgrow="ALWAYS" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </StackPane>
    </children>
</fx:root>